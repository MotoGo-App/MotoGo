# ============================================================
# Variables de entorno de MotoGo - PLANTILLA
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env real a GitHub u otro repo público.
# ============================================================

# --- Base de datos PostgreSQL ---
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://user:password@localhost:5432/motogo

# --- NextAuth ---
# Genera un secreto aleatorio: openssl rand -base64 32
NEXTAUTH_SECRET=
# NEXTAUTH_URL se configura automáticamente en Abacus.AI. Si corres local:
# NEXTAUTH_URL=http://localhost:3000

# --- Cloud Storage (Abacus.AI maneja esto automáticamente) ---
AWS_PROFILE=
AWS_REGION=
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=

# --- Abacus.AI APIs (LLM, notificaciones por email) ---
ABACUSAI_API_KEY=
WEB_APP_ID=
NOTIF_ID_RECUPERACIN_DE_CONTRASEA=

# --- Stripe (opcional, solo si activas pagos) ---
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
